# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
.python-version

# OS
.DS_Store
Thumbs.db

# Editor
.ipynb_checkpoints/
.vscode/
.idea/

# Environment / secrets
.env
*.key

# Logs
*.log

# Audio data — never committed (host separately, e.g. Hugging Face)
data/raw/**
data/processed/**
data/external/staging/
data/external/openslr/clips/
data/external/opensir/clips/
data/external/commonvoice/clips/
*.wav
*.mp3
*.flac

# Numpy feature caches inside data/ (regenerable from raw audio)
data/**/*.npy

# Large model checkpoints (release via Zenodo / GitHub Releases)
models/saved/**/*.keras
models/saved/*_saved_model/
models/saved/**/*_saved_model/
models/kfold/*.keras
models/kfold/*.tflite

# Keep small/critical artifacts even in ignored areas
!data/README.md
!data/external/manifests/
!data/external/manifests/**
!data/external/opensir/scan_keywords.py
!data/external/opensir/utt_spk_text.tsv
!models/saved/mfcc_mean.npy
!models/saved/mfcc_std.npy
!models/saved/label_classes.npy
!models/saved/*_label_classes.npy
!models/saved/v6/*_labels.npy
!models/tflite/

# Build artifacts
build/
dist/
*.egg-info/
